DATABASE_URL=postgresql://postgres:postgres@localhost:5432/at_store
# Copy to .env and fill in. Never commit .env.
# Your Postgres instance also needs the pgvector extension available.
ANTHROPIC_API_KEY=
# Alternative name supported by the scraper:
# ANTHROPIC_KEY=

# Optional: used by category art generation and other Gemini image workflows
GEMINI_API_KEY=
# GOOGLE_API_KEY is also accepted as an alternative
# Used by scripts/generate-listing-images.ts as well.

# Optional override (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=
